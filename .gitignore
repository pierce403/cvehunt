# Raw pi NDJSON event stream can be hundreds of MB of streaming-thinking deltas;
# the human-readable transcript.txt + truncated reasoning.md + distillation.jsonl
# are the persisted distillation corpus instead.
cves/*/runs/*/model_attempt/transcript.ndjson

# Agent-stage workspaces contain prompts, provider events, private execution inputs,
# complete envelopes, and trusted local-audit material.  Only purpose-built public
# projections and explicitly exported published/ artifacts may enter Git.
cves/*/runs/*/models/
cves/*/runs/*/packets/
cves/*/runs/*/callbacks/
